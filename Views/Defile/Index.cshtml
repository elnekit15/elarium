@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Дефіле";
    bool   hasVideo     = ViewBag.HasVideo;
    string description  = ViewBag.Description ?? "";
}

<div class="defile-page">
    <video autoplay loop muted playsinline class="defile-space-bg">
        <source src="/images/space.mp4" type="video/mp4">
    </video>

    <div class="defile-page-overlay"></div>

    <div class="defile-page-content">
        @if (hasVideo)
        {
            <video autoplay loop muted playsinline class="defile-main-video">
                <source src="/images/defile_main.mp4" type="video/mp4">
            </video>
        }
        else
        {
            <div class="defile-placeholder">
                <p>Відео дефіле скоро з&rsquo;явиться</p>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(description))
        {
            <p class="defile-description">@description</p>
        }
    </div>

    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
    {
        <a asp-controller="Defile" asp-action="Manage" class="defile-admin-link">&#9881; Керувати відео</a>
    }
</div>
