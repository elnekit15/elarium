@model IEnumerable<DesignerStore.Models.Product>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight: 300; letter-spacing: 2px;">УПРАВЛІННЯ ТОВАРАМИ</h2>
        <a asp-action="Create" class="btn btn-dark btn-sm rounded-0">ДОДАТИ НОВИЙ</a>
    </div>

    <table class="table align-middle">
        <thead class="text-uppercase small" style="letter-spacing: 1px; background-color: #f9f9f9;">
            <tr>
                <th style="width: 80px;">Фото</th>
                <th>Назва</th>
                <th>Ціна</th>
                <th>Опис</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl)) {
                            <img src="@item.ImageUrl" style="width: 60px; height: 60px; object-fit: cover; border-radius: 2px;" />
                        }
                    </td>
                    <td style="font-weight: 500;">@item.Name</td>
                    <td>@item.Price грн</td>
                    <td class="text-muted small" style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        @item.Description
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark rounded-0 px-3">
                            Редагувати
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>