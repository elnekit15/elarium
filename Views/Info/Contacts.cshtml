@{ ViewData["Title"] = "Контакти"; }

<div class="info-page">
    <h1>Контакти</h1>

    <div class="contacts-grid">
        <div class="contacts-item">
            <span class="contacts-label">Email</span>
            <a href="mailto:hello@elarium.ua" class="contacts-value">hello@elarium.ua</a>
        </div>
        <div class="contacts-item">
            <span class="contacts-label">Телефон</span>
            <a href="tel:+380501234567" class="contacts-value">+38 (050) 123-45-67</a>
        </div>
        <div class="contacts-item">
            <span class="contacts-label">Instagram</span>
            <a href="https://instagram.com/elarium" target="_blank" class="contacts-value">@@elarium</a>
        </div>
        <div class="contacts-item">
            <span class="contacts-label">Telegram</span>
            <a href="https://t.me/elarium" target="_blank" class="contacts-value">@@elarium_ua</a>
        </div>
        <div class="contacts-item">
            <span class="contacts-label">Адреса шоурум</span>
            <span class="contacts-value">Київ, вул. Хрещатик, 12</span>
        </div>
        <div class="contacts-item">
            <span class="contacts-label">Години роботи</span>
            <span class="contacts-value">Пн – Сб: 11:00 – 20:00<br>Нд: 12:00 – 18:00</span>
        </div>
    </div>

    <div class="info-section mt-5">
        <h2>Написати нам</h2>
        <p>
            Якщо у вас є питання щодо замовлення, розмірів або колаборацій — напишіть нам на
            <a href="mailto:hello@elarium.ua" style="color:#111;">hello@elarium.ua</a>.
            Ми відповідаємо протягом одного робочого дня.
        </p>
    </div>
</div>
