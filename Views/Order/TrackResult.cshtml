@model DesignerStore.Models.Order
@using DesignerStore.Models
@{ ViewData["Title"] = $"Замовлення #{Model.Id}"; }

@{
    var steps = new[]
    {
        (OrderStatus.Pending,    "Очікує",     "&#9675;"),   // ○
        (OrderStatus.Paid,       "Оплачено",   "&#10003;"),  // ✓
        (OrderStatus.Processing, "Обробка",    "&#9678;"),   // ◎
        (OrderStatus.Shipped,    "Відправлено","&#8594;"),   // →
        (OrderStatus.Delivered,  "Доставлено", "&#9670;"),   // ◆
    };

    string StatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "Очікує оплати",
        OrderStatus.Paid       => "Оплачено",
        OrderStatus.Processing => "В обробці",
        OrderStatus.Shipped    => "Відправлено",
        OrderStatus.Delivered  => "Доставлено",
        OrderStatus.Cancelled  => "Скасовано",
        _                      => s.ToString()
    };
    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "#888",
        OrderStatus.Paid       => "#28a745",
        OrderStatus.Processing => "#007bff",
        OrderStatus.Shipped    => "#6f42c1",
        OrderStatus.Delivered  => "#111",
        OrderStatus.Cancelled  => "#dc3545",
        _                      => "#888"
    };
}

<div class="container mt-5 mb-5" style="max-width:680px;">

    <div class="d-flex align-items-center gap-3 mb-5">
        <h2 style="font-weight:300;letter-spacing:2px;margin:0;">ЗАМОВЛЕННЯ #@Model.Id</h2>
        <span style="font-size:0.72rem;letter-spacing:1px;text-transform:uppercase;
                     color:@StatusColor(Model.Status);font-weight:600;margin-left:auto;">
            @StatusLabel(Model.Status)
        </span>
    </div>

    @* ─── Таймлайн статусів ─────────────────────────────── *@
    @if (Model.Status != OrderStatus.Cancelled)
    {
        <div class="mb-5">
            <div class="d-flex align-items-center" style="position:relative;">
                @for (int i = 0; i < steps.Length; i++)
                {
                    var (st, label, icon) = steps[i];
                    var reached  = (int)Model.Status >= (int)st;
                    var isCurrent = Model.Status == st;

                    <div style="flex:1;text-align:center;position:relative;z-index:1;">
                        <div style="width:36px;height:36px;border-radius:50%;margin:0 auto 6px;
                                    background:@(reached ? "#111" : "#e0e0e0");
                                    color:@(reached ? "#fff" : "#aaa");
                                    display:flex;align-items:center;justify-content:center;
                                    font-size:0.85rem;
                                    box-shadow:@(isCurrent ? "0 0 0 3px #11111133" : "none");
                                    transition:background 0.3s;">
                            @Html.Raw(icon)
                        </div>
                        <div style="font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;
                                    color:@(reached ? "#111" : "#aaa");font-weight:@(isCurrent ? "700" : "400");">
                            @label
                        </div>
                    </div>

                    @if (i < steps.Length - 1)
                    {
                        var lineReached = (int)Model.Status > (int)st;
                        <div style="flex:1;height:2px;background:@(lineReached ? "#111" : "#e0e0e0");
                                    margin-bottom:20px;z-index:0;"></div>
                    }
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert rounded-0 mb-5" style="background:#fdf0f0;border-color:#dc3545;color:#dc3545;font-size:0.82rem;letter-spacing:1px;">
            Це замовлення було скасовано
        </div>
    }

    @* ─── Товари ─────────────────────────────────────────── *@
    <div class="border p-4 mb-4">
        <h6 class="text-uppercase mb-3" style="font-size:0.68rem;letter-spacing:2px;color:#888;">Товари</h6>

        @foreach (var item in Model.Items)
        {
            <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" style="width:55px;height:70px;object-fit:cover;flex-shrink:0;" />
                }
                <div class="flex-grow-1" style="font-size:0.82rem;">
                    <div style="font-weight:600;">@item.ProductName</div>
                    <div class="text-muted">Розмір: @item.Size · @item.Quantity шт.</div>
                </div>
                <div style="font-weight:600;font-size:0.82rem;">@(item.Price * item.Quantity) грн</div>
            </div>
        }

        <div class="d-flex justify-content-between pt-1">
            <span class="text-uppercase small" style="letter-spacing:1px;">Разом</span>
            <strong>@Model.TotalAmount грн</strong>
        </div>
    </div>

    @* ─── Дані покупця ───────────────────────────────────── *@
    <div class="border p-4 mb-5" style="font-size:0.83rem;">
        <h6 class="text-uppercase mb-3" style="font-size:0.68rem;letter-spacing:2px;color:#888;">Дані доставки</h6>
        <div class="row g-2">
            <div class="col-4 text-muted small text-uppercase" style="letter-spacing:0.5px;">Отримувач</div>
            <div class="col-8">@Model.CustomerName</div>
            <div class="col-4 text-muted small text-uppercase" style="letter-spacing:0.5px;">Телефон</div>
            <div class="col-8">@Model.CustomerPhone</div>
            <div class="col-4 text-muted small text-uppercase" style="letter-spacing:0.5px;">Доставка</div>
            <div class="col-8">@Model.City, @Model.Address</div>
            <div class="col-4 text-muted small text-uppercase" style="letter-spacing:0.5px;">Дата</div>
            <div class="col-8 text-muted small">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <a asp-action="Track" class="btn btn-outline-dark rounded-0 px-4" style="font-size:0.72rem;letter-spacing:1px;">
            ← Перевірити інше замовлення
        </a>
        <a asp-controller="Home" asp-action="Landing" class="btn btn-dark rounded-0 px-4" style="font-size:0.72rem;letter-spacing:1px;">
            До магазину
        </a>
    </div>
</div>
