@model DesignerStore.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Оформлення замовлення";
    var cart = ViewBag.Cart as List<DesignerStore.Models.CartItem> ?? new();
}

<div class="container mt-5 mb-5">
    <h2 class="mb-4" style="font-weight:300;letter-spacing:2px;">ОФОРМЛЕННЯ ЗАМОВЛЕННЯ</h2>
    <hr />

    <div class="row g-5">
        <div class="col-lg-7">
            <h5 class="mb-3 text-uppercase" style="font-size:0.72rem;letter-spacing:3px;font-weight:600;">Дані покупця</h5>

            <form asp-action="Checkout" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label small text-uppercase">ПІБ</label>
                    <input asp-for="Name" class="form-control rounded-0" placeholder="Іваненко Іван Іванович" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label small text-uppercase">Email</label>
                        <input asp-for="Email" type="email" class="form-control rounded-0" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label small text-uppercase">Телефон</label>
                        <input asp-for="Phone" class="form-control rounded-0" placeholder="+380 xx xxx xx xx" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-5 mb-3">
                        <label asp-for="City" class="form-label small text-uppercase">Місто</label>
                        <input asp-for="City" class="form-control rounded-0" placeholder="Київ" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-7 mb-3">
                        <label asp-for="Address" class="form-label small text-uppercase">Відділення Нової Пошти / Адреса</label>
                        <input asp-for="Address" class="form-control rounded-0" placeholder="Нова Пошта №5" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <h5 class="text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:3px;font-weight:600;">Спосіб оплати</h5>
                    <div class="d-flex gap-3">

                        <label class="flex-fill" style="cursor:pointer;" id="lbl-stripe">
                            <input type="radio" asp-for="PaymentMethod" value="stripe" class="visually-hidden pm-radio" />
                            <div class="pm-box border p-3 d-flex align-items-center gap-3">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                                    <line x1="1" y1="10" x2="23" y2="10"/>
                                </svg>
                                <div>
                                    <div style="font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Картка (Stripe)</div>
                                    <div class="text-muted" style="font-size:0.65rem;">Visa / Mastercard</div>
                                </div>
                            </div>
                        </label>

                        <label class="flex-fill" style="cursor:pointer;" id="lbl-wfp">
                            <input type="radio" asp-for="PaymentMethod" value="wayforpay" class="visually-hidden pm-radio" />
                            <div class="pm-box border p-3 d-flex align-items-center gap-3">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                    <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                                    <line x1="9" y1="9" x2="9.01" y2="9"/>
                                    <line x1="15" y1="9" x2="15.01" y2="9"/>
                                </svg>
                                <div>
                                    <div style="font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">WayForPay</div>
                                    <div class="text-muted" style="font-size:0.65rem;">Українська платіжна система</div>
                                </div>
                            </div>
                        </label>

                    </div>
                </div>

                <button type="submit" class="btn btn-dark rounded-0 px-5 mt-4 w-100" style="height:48px;letter-spacing:2px;font-size:0.72rem;">
                    ПЕРЕЙТИ ДО ОПЛАТИ
                </button>
                <a asp-controller="Cart" asp-action="Index" class="btn btn-link text-dark text-decoration-none small d-block text-center mt-2">
                    ← Повернутись до кошика
                </a>
            </form>
        </div>

        <div class="col-lg-5">
            <h5 class="mb-3 text-uppercase" style="font-size:0.72rem;letter-spacing:3px;font-weight:600;">Ваше замовлення</h5>
            <div class="border p-3">
                @foreach (var item in cart)
                {
                    <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                        <img src="@item.ImageUrl" style="width:60px;height:80px;object-fit:cover;flex-shrink:0;" />
                        <div class="flex-grow-1" style="font-size:0.82rem;">
                            <div style="font-weight:600;">@item.Name</div>
                            <div class="text-muted">Розмір: @item.Size</div>
                            <div class="text-muted">Кількість: @item.Quantity</div>
                        </div>
                        <div style="font-weight:600;font-size:0.82rem;white-space:nowrap;">
                            @(item.Price * item.Quantity) грн
                        </div>
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center pt-2">
                    <span class="text-uppercase small" style="letter-spacing:1px;">Разом</span>
                    <strong style="font-size:1.05rem;">@cart.Sum(i => i.Price * i.Quantity) грн</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .pm-box {
            border-color: #ddd !important;
            transition: border-color 0.18s, background 0.18s;
            min-height: 68px;
        }
        .pm-box:hover { border-color: #999 !important; }
        label:has(.pm-radio:checked) .pm-box {
            border-color: #111 !important;
            background: #f8f8f8;
        }
    </style>
    <script>
        // Fallback for browsers without :has() support
        document.querySelectorAll('.pm-radio').forEach(function (radio) {
            radio.addEventListener('change', function () {
                document.querySelectorAll('.pm-box').forEach(b => {
                    b.style.borderColor = '';
                    b.style.background  = '';
                });
                if (this.checked) {
                    const box = this.closest('label').querySelector('.pm-box');
                    box.style.borderColor = '#111';
                    box.style.background  = '#f8f8f8';
                }
            });
        });
        // Init default (stripe)
        const defaultRadio = document.querySelector('.pm-radio[value="stripe"]');
        if (defaultRadio) defaultRadio.dispatchEvent(new Event('change'));
    </script>
}
