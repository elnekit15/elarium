@model List<(string Name, string Value)>
@{
    ViewData["Title"] = "Оплата";
}

<div class="container d-flex flex-column align-items-center justify-content-center" style="min-height:60vh;gap:1.6rem;">
    <div class="text-center">
        <p class="text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:3px;color:#888;">
            Перенаправлення на сторінку оплати…
        </p>
        <div class="spinner-border" style="width:1.8rem;height:1.8rem;border-width:2px;color:#111;" role="status">
            <span class="visually-hidden">Завантаження...</span>
        </div>
    </div>

    <form id="wfp-form" action="@DesignerStore.Services.WayForPayService.PaymentUrl" method="post" style="display:none;">
        @foreach (var field in Model)
        {
            <input type="hidden" name="@field.Name" value="@field.Value" />
        }
    </form>
</div>

@section Scripts {
    <script>
        window.addEventListener('load', function () {
            document.getElementById('wfp-form').submit();
        });
    </script>
}
