@model List<DesignerStore.Models.Order>
@using DesignerStore.Models
@{
    ViewData["Title"] = "Замовлення";

    string StatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "Очікує оплати",
        OrderStatus.Paid       => "Оплачено",
        OrderStatus.Processing => "В обробці",
        OrderStatus.Shipped    => "Відправлено",
        OrderStatus.Delivered  => "Доставлено",
        OrderStatus.Cancelled  => "Скасовано",
        _                      => s.ToString()
    };
    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "#888",
        OrderStatus.Paid       => "#28a745",
        OrderStatus.Processing => "#007bff",
        OrderStatus.Shipped    => "#6f42c1",
        OrderStatus.Delivered  => "#111",
        OrderStatus.Cancelled  => "#dc3545",
        _                      => "#888"
    };
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:300;letter-spacing:2px;">ЗАМОВЛЕННЯ</h2>
        <span class="text-muted small">Всього: @Model.Count</span>
    </div>
    <hr />

    @if (TempData["DeletedOrder"] != null)
    {
        <div class="alert rounded-0 border-0 mb-3 py-2 px-3"
             style="background:#f8f8f8;font-size:.75rem;letter-spacing:.5px;color:#555;">
            Замовлення #@TempData["DeletedOrder"] видалено.
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">Замовлень ще немає</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr class="text-uppercase small text-muted">
                        <th>#</th>
                        <th>Покупець</th>
                        <th>Дата</th>
                        <th>Товарів</th>
                        <th>Сума</th>
                        <th>Статус</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="text-muted small">@order.Id</td>
                            <td>
                                <div style="font-weight:600;font-size:0.85rem;">@order.CustomerName</div>
                                <div class="text-muted small">@order.CustomerEmail</div>
                            </td>
                            <td class="small text-muted">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="small">@order.Items.Sum(i => i.Quantity) шт.</td>
                            <td style="font-weight:600;">@order.TotalAmount грн</td>
                            <td>
                                <span style="font-size:0.72rem;letter-spacing:1px;text-transform:uppercase;color:@StatusColor(order.Status);font-weight:600;">
                                    @StatusLabel(order.Status)
                                </span>
                            </td>
                            <td class="text-end" style="white-space:nowrap;">
                                <a asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-outline-dark btn-sm rounded-0" style="font-size:0.68rem;letter-spacing:1px;">
                                    Деталі
                                </a>
                                <button type="button"
                                        class="btn btn-sm rounded-0 ms-1"
                                        style="width:32px;padding:.25rem;border:1px solid #e0e0e0;color:#bbb;"
                                        title="Видалити замовлення"
                                        onclick="openDeleteOrder(@order.Id)">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="1.8"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                        <path d="M10 11v6M14 11v6"/>
                                        <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- ── Delete order confirmation modal ─────────────────────── -->
<div class="modal fade" id="delOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
        <div class="modal-content rounded-0 border" style="box-shadow:0 12px 48px rgba(0,0,0,.1);">
            <div class="modal-body p-4 text-center">

                <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                     stroke="#ccc" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"
                     class="mb-3">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                </svg>

                <p style="font-size:.85rem;font-weight:500;margin-bottom:.4rem;">
                    Видалити замовлення <span id="del-order-num" style="font-weight:700;"></span>?
                </p>
                <p class="text-muted mb-4" style="font-size:.72rem;">
                    Всі позиції замовлення також будуть видалені.<br>Цю дію неможливо скасувати.
                </p>

                <div class="d-flex gap-2 justify-content-center">
                    <button type="button"
                            class="btn btn-outline-dark rounded-0 btn-sm px-4"
                            style="font-size:.68rem;letter-spacing:1px;"
                            data-bs-dismiss="modal">
                        Скасувати
                    </button>
                    <form id="del-order-form" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-dark rounded-0 btn-sm px-4"
                                style="font-size:.68rem;letter-spacing:1px;">
                            Видалити
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openDeleteOrder(id) {
    document.getElementById('del-order-num').textContent = '#' + id;
    document.getElementById('del-order-form').action = '/Orders/Delete/' + id;
    new bootstrap.Modal(document.getElementById('delOrderModal')).show();
}
</script>
}
