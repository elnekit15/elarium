@model DesignerStore.Models.Order
@using DesignerStore.Models
@{
    ViewData["Title"] = $"Замовлення #{Model.Id}";

    string StatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "Очікує оплати",
        OrderStatus.Paid       => "Оплачено",
        OrderStatus.Processing => "В обробці",
        OrderStatus.Shipped    => "Відправлено",
        OrderStatus.Delivered  => "Доставлено",
        OrderStatus.Cancelled  => "Скасовано",
        _                      => s.ToString()
    };
    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "#888",
        OrderStatus.Paid       => "#28a745",
        OrderStatus.Processing => "#007bff",
        OrderStatus.Shipped    => "#6f42c1",
        OrderStatus.Delivered  => "#111",
        OrderStatus.Cancelled  => "#dc3545",
        _                      => "#888"
    };
}

<div class="container mt-5 mb-5" style="max-width:860px;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-dark btn-sm rounded-0" style="font-size:0.68rem;letter-spacing:1px;">
            ← Назад
        </a>
        <h2 style="font-weight:300;letter-spacing:2px;margin:0;">ЗАМОВЛЕННЯ #@Model.Id</h2>
        <span style="font-size:0.72rem;letter-spacing:1px;text-transform:uppercase;
                     color:@StatusColor(Model.Status);font-weight:600;margin-left:auto;">
            @StatusLabel(Model.Status)
        </span>
    </div>
    <hr />

    <div class="row g-4">

        @* Left column: items *@
        <div class="col-lg-7">
            <h6 class="text-uppercase mb-3" style="font-size:0.68rem;letter-spacing:2px;color:#888;">Товари</h6>

            @foreach (var item in Model.Items)
            {
                <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" style="width:55px;height:70px;object-fit:cover;flex-shrink:0;" />
                    }
                    else
                    {
                        <div style="width:55px;height:70px;background:#f5f5f5;flex-shrink:0;"></div>
                    }
                    <div class="flex-grow-1" style="font-size:0.82rem;">
                        <div style="font-weight:600;">@item.ProductName</div>
                        <div class="text-muted">Розмір: @item.Size</div>
                        <div class="text-muted">Кількість: @item.Quantity шт.</div>
                        <div class="text-muted">Ціна: @item.Price грн/шт.</div>
                    </div>
                    <div style="font-weight:600;font-size:0.85rem;white-space:nowrap;">
                        @(item.Price * item.Quantity) грн
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center pt-2">
                <span class="text-uppercase small" style="letter-spacing:1px;">Разом</span>
                <strong style="font-size:1.05rem;">@Model.TotalAmount грн</strong>
            </div>
        </div>

        @* Right column: customer info + status update *@
        <div class="col-lg-5">

            <div class="border p-3 mb-4" style="font-size:0.83rem;">
                <h6 class="text-uppercase mb-3" style="font-size:0.68rem;letter-spacing:2px;color:#888;">Покупець</h6>
                <div class="row g-2">
                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Ім'я</div>
                    <div class="col-7" style="font-weight:600;">@Model.CustomerName</div>

                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Email</div>
                    <div class="col-7">
                        <a href="mailto:@Model.CustomerEmail" class="text-dark" style="font-size:0.8rem;">@Model.CustomerEmail</a>
                    </div>

                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Телефон</div>
                    <div class="col-7">@Model.CustomerPhone</div>

                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Місто</div>
                    <div class="col-7">@Model.City</div>

                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Адреса</div>
                    <div class="col-7">@Model.Address</div>

                    <div class="col-5 text-muted small text-uppercase" style="letter-spacing:0.5px;">Дата</div>
                    <div class="col-7 small text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.StripeSessionId))
            {
                <div class="border p-3 mb-4" style="font-size:0.75rem;color:#888;">
                    <div class="text-uppercase mb-1" style="letter-spacing:1px;">Stripe Session</div>
                    <div style="word-break:break-all;">@Model.StripeSessionId</div>
                    @if (!string.IsNullOrEmpty(Model.PaymentIntentId))
                    {
                        <div class="text-uppercase mb-1 mt-2" style="letter-spacing:1px;">Payment Intent</div>
                        <div style="word-break:break-all;">@Model.PaymentIntentId</div>
                    }
                </div>
            }

            <div class="border p-3">
                <h6 class="text-uppercase mb-3" style="font-size:0.68rem;letter-spacing:2px;color:#888;">Змінити статус</h6>
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <select name="status" class="form-select rounded-0" style="font-size:0.82rem;">
                            @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                            {
                                var val      = (int)s;
                                var label    = StatusLabel(s);
                                var selected = Model.Status == s;
                                <option value="@val" selected="@selected">@label</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dark rounded-0 w-100" style="font-size:0.72rem;letter-spacing:2px;height:40px;">
                        ОНОВИТИ СТАТУС
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>
