@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "ПАРОЛЬ ЗМІНЕНО";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4 border p-4 bg-light shadow-sm text-center">

            <div class="mb-3" style="font-size:2rem;">&#10003;</div>
            <h2 class="mb-3" style="font-weight:400;letter-spacing:2px;">@ViewData["Title"]</h2>

            <p class="text-muted" style="font-size:0.9rem;line-height:1.7;">
                Ваш пароль успішно змінено.<br>
                Тепер ви можете увійти з новим паролем.
            </p>

            <div class="mt-4">
                <a asp-page="./Login"
                   class="btn btn-outline-dark rounded-0 px-4 py-2"
                   style="letter-spacing:1px;font-size:0.85rem;">
                    УВІЙТИ
                </a>
            </div>

        </div>
    </div>
</div>
