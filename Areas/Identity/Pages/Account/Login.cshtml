@page
@model LoginModel
@{
    ViewData["Title"] = "ВХІД";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4 border p-4 bg-light shadow-sm">
            
            <h2 class="text-center mb-4" style="font-weight: 400; letter-spacing: 2px;">@ViewData["Title"]</h2>
            
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control rounded-0 border-dark" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label text-muted">Електронна пошта</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control rounded-0 border-dark" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label text-muted">Пароль</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                
                <div class="checkbox mb-4">
                    <label asp-for="Input.RememberMe" class="form-label small">
                        <input class="form-check-input border-dark rounded-0" asp-for="Input.RememberMe" />
                        Запам'ятати мене
                    </label>
                </div>
                
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn py-3 btn-outline-dark rounded-0 text-dark fw-bold" style="letter-spacing: 1.5px;">УВІЙТИ</button>
                </div>
                
                <div class="mt-4 text-center small">
                    <p><a id="forgot-password" asp-page="./ForgotPassword" class="text-dark text-decoration-none border-bottom border-dark pb-1">Забули пароль?</a></p>
                    <p class="mt-3">Немає акаунта? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-dark fw-bold text-decoration-none">Зареєструватися</a></p>
                </div>
            </form>

            @if (Model.ExternalLogins?.Count > 0)
            {
                <div class="d-flex align-items-center my-4 gap-2">
                    <hr class="flex-grow-1 m-0" />
                    <span class="text-muted small px-2" style="white-space:nowrap;letter-spacing:1px;">або</span>
                    <hr class="flex-grow-1 m-0" />
                </div>

                <form id="external-account" asp-area="Identity" asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" name="provider" value="@provider.Name"
                                class="w-100 btn btn-outline-secondary rounded-0 py-2 mb-2 d-flex align-items-center justify-content-center gap-2"
                                style="font-size:0.8rem;letter-spacing:1px;border-color:#ddd;">
                            @if (provider.Name == "Google")
                            {
                                <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                    <path fill="none" d="M0 0h48v48H0z"/>
                                </svg>
                            }
                            Увійти через @provider.DisplayName
                        </button>
                    }
                </form>
            }

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}