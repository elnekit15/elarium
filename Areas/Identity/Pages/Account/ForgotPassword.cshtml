@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "ЗАБУЛИ ПАРОЛЬ?";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4 border p-4 bg-light shadow-sm">

            <h2 class="text-center mb-2" style="font-weight:400;letter-spacing:2px;">@ViewData["Title"]</h2>
            <p class="text-center text-muted small mb-4" style="line-height:1.6;">
                Введіть вашу пошту — ми надішлемо посилання для скидання паролю.
            </p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control rounded-0 border-dark"
                           autocomplete="username"
                           placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label text-muted">Електронна пошта</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div>
                    <button type="submit"
                            class="w-100 btn py-3 btn-outline-dark rounded-0 fw-bold"
                            style="letter-spacing:1.5px;">
                        НАДІСЛАТИ ПОСИЛАННЯ
                    </button>
                </div>

                <div class="mt-4 text-center small">
                    <a asp-page="./Login"
                       class="text-dark text-decoration-none border-bottom border-dark pb-1">
                        ← Назад до входу
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
