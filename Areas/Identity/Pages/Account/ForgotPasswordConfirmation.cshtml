@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "ЛИСТ НАДІСЛАНО";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4 border p-4 bg-light shadow-sm text-center">

            <div class="mb-3" style="font-size:2rem;">&#9993;</div>
            <h2 class="mb-3" style="font-weight:400;letter-spacing:2px;">@ViewData["Title"]</h2>

            <p class="text-muted" style="font-size:0.9rem;line-height:1.7;">
                Якщо акаунт з такою поштою існує, ми надіслали посилання для скидання паролю.<br>
                Перевірте вашу поштову скриньку, а також папку <em>Spam</em>.
            </p>

            <div class="mt-4">
                <a asp-page="./Login"
                   class="btn btn-outline-dark rounded-0 px-4 py-2"
                   style="letter-spacing:1px;font-size:0.85rem;">
                    НАЗАД ДО ВХОДУ
                </a>
            </div>

        </div>
    </div>
</div>
