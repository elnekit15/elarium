@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "НОВИЙ ПАРОЛЬ";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4 border p-4 bg-light shadow-sm">

            <h2 class="text-center mb-4" style="font-weight:400;letter-spacing:2px;">@ViewData["Title"]</h2>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <input asp-for="Input.Code" type="hidden" />

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control rounded-0 border-dark"
                           autocomplete="username"
                           placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label text-muted">Електронна пошта</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password"
                           class="form-control rounded-0 border-dark"
                           autocomplete="new-password"
                           placeholder="password" />
                    <label asp-for="Input.Password" class="form-label text-muted">Новий пароль</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control rounded-0 border-dark"
                           autocomplete="new-password"
                           placeholder="confirm-password" />
                    <label asp-for="Input.ConfirmPassword" class="form-label text-muted">Підтвердити пароль</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <div>
                    <button type="submit"
                            class="w-100 btn py-3 btn-outline-dark rounded-0 fw-bold"
                            style="letter-spacing:1.5px;">
                        ЗБЕРЕГТИ ПАРОЛЬ
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
